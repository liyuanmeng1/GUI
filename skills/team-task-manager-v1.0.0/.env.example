# TEAM Task Manager 配置文件示例
# 复制此文件为 .env 并根据实际情况修改

# API 认证信息（必填）
TEAM_APP_KEY="your_app_key_here"
TEAM_SECRET_KEY="your_secret_key_here"

# 默认项目配置（可选）
TEAM_PROJECT_ID="P98273"
TEAM_OPERATOR="wangyihan"

# 默认任务分类（可选）
TEAM_TASK_CLASS_ID="287676"  # 产品需求

# 默认任务组
SECTION_ID="S248305"    # 客户端

# 默认优先级
# 65: 中等
# 64: 高优
# 63: 最高优
DEFAULT_PRIORITY="65"

# 默认状态（根据实际工作流配置）
DEFAULT_STATUS="3215447"

# API 基础地址
BASE_URL="https://is-gateway.corp.kuaishou.com"

# 常用项目配置参考
# ----------------------
# 项目 P98273（研发效能中心）
# - 任务分类：
#   - 287676: 产品需求
#   - 287681: 技术预研
# - 任务组：
#   - S248305: 客户端
